{
  "expo": {
    "name": "Watch Togather",
    "slug": "watch-togather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/watch-togather-light.png",
    "userInterfaceStyle": "automatic",
    "scheme": "watch-togather",
    "splash": {
      "image": "./assets/watch-togather-light.png",
      "dark": {
        "image": "./assets/watch-togather-dark.png",
        "backgroundColor": "#000000"
      },
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/watch-togather-light.png",
        "monochromeImage": "./assets/watch-togather-dark.png",
        "backgroundColor": "#ffffff",
        "backgroundColorDark": "#000000"
      },
      "package": "com.saniyaj.watchtogather",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fa13422c-b714-4d65-af2d-301e4a2a055e"
      }
    }
  }
}
